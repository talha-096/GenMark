# GenMark Backend Environment Variables Example
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your_super_secret_key_here

# MongoDB Configuration
MONGO_URI=mongodb://mongodb:27017/genmark
# If using Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/genmark

# AI API Keys (KEEP PRIVATE)
OPENAI_API_KEY=sk-xxxx...
STABILITY_API_KEY=sk-xxxx...

# JWT Setting
JWT_SECRET_KEY=jwt_secret_key_here
