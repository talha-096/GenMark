# Universal .gitignore for GenMark Monorepo
# Restrict repository to only Frontend and Backend source code

# [Ignore Everything by Default]
/*
!/Frontend/
!/Backend/
!/.github/
!/.gitignore
!/README.md
!/docker-compose.yml

# [Backend] Python Specifics (within Backend folder)
Backend/__pycache__/
Backend/*.py[cod]
Backend/*$py.class
Backend/.env*
Backend/.venv/
Backend/instance/
Backend/htmlcov/
Backend/.pytest_cache/
Backend/.mypy_cache/
Backend/.tox/
Backend/.nox/
Backend/.coverage
Backend/.coverage.*
Backend/cache/
Backend/nosetests.xml
Backend/coverage.xml
Backend/*.db
Backend/*.db-journal
Backend/Model/
Backend/*.safetensors
Backend/secrets/

# [Frontend] Node Specifics (within Frontend folder)
Frontend/node_modules/
Frontend/dist/
Frontend/.env
Frontend/*.log
Frontend/.eslintcache
Frontend/.prettiercache
Frontend/.turbo/
Frontend/testsprite_tests/

# [IDE & OS]
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# [Custom Models & Large Files]
Model/
*.safetensors
*.bin
*.pt
*.onnx

# [Secrets & Keys]
*.env*
!*.env.example
*.pem
*.key
*.cert
*.crt
*.p12
*.jks
secrets.json
credentials.json
auth.json
*.pcap
*.cap
